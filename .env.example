# ============================================================================
# SECURITY WARNING: DO NOT COMMIT REAL CREDENTIALS TO VERSION CONTROL
# ============================================================================
# This file contains PLACEHOLDER values only.
# Copy this to .env.local and fill with your actual credentials.
# .env.local is git-ignored and will not be committed.
# 
# Configure your Zoho endpoint below.
# If you expose any secret endpoint/token, rotate it immediately.
# ============================================================================

# Frontend endpoint for contact submissions
# Use default '/api/contact' for local/prod proxy flow
VITE_CONTACT_API_URL=/api/contact

# Local dev proxy secret (do NOT use VITE_ for secrets)
# Vite proxy will read this and forward /api/contact server-side.
ZOHO_WEBHOOK_URL=https://your-zoho-endpoint-here

# Maintenance mode: set to 'true' to show maintenance page for all routes (except Contact)
VITE_MAINTENANCE_MODE=false

